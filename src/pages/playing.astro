---
import Layout from "../layouts/Layout.astro";
import { supabaseClient } from "../lib/supabase";

const supabase = supabaseClient(Astro);
const { data: { user } } = await supabase.auth.getUser();
---
<Layout title="Top 50 Public Golf Courses in America" user={user}>
  <main class="max-w-3xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-extrabold text-green-800 mb-8 text-center">Top 10 Public Golf Courses in America</h1>
    <ol class="space-y-4">
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://www.bandondunesgolf.com/golf/courses/pacific-dunes/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Pacific Dunes (Bandon Dunes Resort, Oregon)</a>
        <p class="text-gray-600 mt-1">A dramatic links course on the Oregon coast, known for its natural dunes and ocean views.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://www.pebblebeach.com/golf/pebble-beach-golf-links/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Pebble Beach Golf Links (Pebble Beach, California)</a>
        <p class="text-gray-600 mt-1">Iconic Monterey Peninsula course with stunning ocean holes and major championship history.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://www.destinationkohler.com/golf/whistling-straits/straits-course" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Whistling Straits (Straits Course, Wisconsin)</a>
        <p class="text-gray-600 mt-1">Pete Dye’s links-style masterpiece on Lake Michigan, famous for its bunkers and championship pedigree.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://www.pinehurst.com/golf/courses/no-2/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Pinehurst No. 2 (Pinehurst Resort, North Carolina)</a>
        <p class="text-gray-600 mt-1">Donald Ross’s legendary design, host to multiple U.S. Opens and revered for its crowned greens.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://www.chambersbaygolf.com/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Chambers Bay (University Place, Washington)</a>
        <p class="text-gray-600 mt-1">Modern links on Puget Sound, site of the 2015 U.S. Open, known for elevation changes and walkability.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://www.streamsongresort.com/golf/blue/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Streamsong Resort (Blue Course, Florida)</a>
        <p class="text-gray-600 mt-1">Tom Doak’s acclaimed course on reclaimed mining land, praised for strategic design and firm conditions.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://www.sandvalley.com/golf/sand-valley/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Sand Valley (Sand Valley Golf Resort, Wisconsin)</a>
        <p class="text-gray-600 mt-1">Coore & Crenshaw’s minimalist links in central Wisconsin, celebrated for its natural routing and firm play.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://www.cabotcapebreton.com/golf/cabot-cliffs/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Cabot Cliffs (Cabot Cape Breton, Nova Scotia)</a>
        <p class="text-gray-600 mt-1">Dramatic cliffside golf in Canada, with ocean views and a minimalist design by Coore & Crenshaw.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://kiawahresort.com/golf/the-ocean-course/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Kiawah Island (Ocean Course, South Carolina)</a>
        <p class="text-gray-600 mt-1">Pete Dye’s challenging seaside course, famous for the 1991 Ryder Cup and major championships.</p>
      </li>
      <li class="bg-white rounded-xl shadow p-5 border-l-4 border-green-400 hover:border-blue-500 transition">
        <a href="https://arcadiabluffs.com/" target="_blank" class="text-xl font-bold text-blue-700 hover:underline">Arcadia Bluffs (Arcadia, Michigan)</a>
        <p class="text-gray-600 mt-1">Links-style golf on Lake Michigan bluffs, known for elevation changes and spectacular views.</p>
      </li>
    </ol>
    <p class="mt-8 text-center text-gray-600 text-sm">
      Source: <a href="https://burlingameccwnc.com/top-50-public-golf-courses-in-america/" class="text-blue-700 hover:underline" target="_blank" rel="noopener">burlingameccwnc.com</a>
    </p>
  </main>
</Layout>
