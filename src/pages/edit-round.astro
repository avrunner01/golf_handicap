---
import Layout from '../layouts/Layout.astro';
import { supabaseClient } from '../lib/supabase';

const supabase = supabaseClient(Astro);
const { data: { user } } = await supabase.auth.getUser();

const roundId = Astro.url.searchParams.get('id') ?? '';
const routeError = Astro.url.searchParams.get('error') ?? '';
const maxPlayedAt = new Date().toISOString().split('T')[0];
let round = null;
let pageError = routeError;

if (!user) {
  return Astro.redirect('/login');
}

if (!roundId) {
  pageError = 'Missing round ID.';
} else {
  const { data, error } = await supabase
    .from('rounds')
    .select('id, course_name, tee_id, gross_score, played_at, profile_id')
    .eq('id', roundId)
    .eq('profile_id', user.id)
    .single();

  if (error || !data) {
    pageError = 'Round not found or you do not have access to edit it.';
  } else {
    round = data;
  }
}
---

<Layout title="Edit Round" user={user}>
  <main class="max-w-2xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Edit Round</h1>

    {pageError ? (
      <div class="rounded-md border border-red-200 bg-red-50 p-4 text-red-700">
        {pageError}
      </div>
    ) : (
      <form action="/api/rounds/update" method="POST" class="space-y-6 bg-white p-8 rounded-xl shadow-sm border border-gray-100">
        <input type="hidden" name="id" value={round?.id ?? ''} />
        <input type="hidden" name="tee_id" value={round?.tee_id ?? ''} />

        <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 shadow-sm">
          <p class="text-sm font-semibold text-blue-900 mb-1">Course</p>
          <p class="text-base font-bold text-blue-800">{round?.course_name ?? 'Unknown course'}</p>
          <p class="mt-1 text-xs text-blue-700">Only score and date are editable.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="rounded-xl border border-green-200 bg-green-50 p-4 shadow-sm">
            <label class="block text-sm font-semibold text-green-900 mb-1" for="gross_score">Gross Score</label>
            <input
              id="gross_score"
              type="number"
              name="gross_score"
              required
              min="30"
              max="200"
              value={round?.gross_score ?? ''}
              class="block w-full rounded-md border-gray-300 shadow-sm focus:border-green-600 focus:ring-green-600"
            />
          </div>
          <div class="rounded-xl border border-green-200 bg-green-50 p-4 shadow-sm">
            <label class="block text-sm font-semibold text-green-900 mb-1" for="played_at">Date Played</label>
            <input
              id="played_at"
              type="date"
              name="played_at"
              required
              max={maxPlayedAt}
              value={round?.played_at ? String(round.played_at).split('T')[0] : ''}
              class="block w-full rounded-md border-gray-300 shadow-sm focus:border-green-600 focus:ring-green-600"
            />
          </div>
        </div>

        <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
          <a href="/dashboard" class="w-full rounded-md border border-gray-300 bg-white py-3 px-4 text-center font-semibold text-gray-700 hover:bg-gray-50 sm:w-auto">
            Cancel
          </a>
          <button type="submit" class="w-full bg-green-600 text-white py-3 px-4 rounded-md font-semibold hover:bg-green-700 transition-colors sm:w-auto">
            Update Round
          </button>
        </div>
      </form>
    )}
  </main>
</Layout>
