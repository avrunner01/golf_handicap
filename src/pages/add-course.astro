---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Add Course">
  <main class="max-w-2xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Add New Course</h1>
    <form action="/api/courses/create" method="POST" class="space-y-6 bg-white p-8 rounded-xl shadow-sm border border-gray-100">
      <div class="rounded-xl border border-green-200 bg-green-50 p-4 shadow-sm mb-2">
        <label class="block text-sm font-semibold text-green-900 mb-1">Course Name</label>
        <input type="text" name="course_name" required class="block w-full rounded-md border-gray-300 shadow-sm focus:border-green-600 focus:ring-green-600" />
      </div>
      <div class="rounded-xl border border-green-200 bg-green-50 p-4 shadow-sm mb-2">
        <label class="block text-sm font-semibold text-green-900 mb-1">Tee Name</label>
        <input type="text" name="tee_name" required class="block w-full rounded-md border-gray-300 shadow-sm focus:border-green-600 focus:ring-green-600" />
      </div>
      <div class="rounded-xl border border-green-200 bg-green-50 p-4 shadow-sm mb-2">
        <label class="block text-sm font-semibold text-green-900 mb-1">Color Code</label>
        <input type="text" name="color_code" required class="block w-full rounded-md border-gray-300 shadow-sm focus:border-green-600 focus:ring-green-600" />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-xl border border-green-200 bg-green-50 p-4 shadow-sm mb-2">
          <label class="block text-sm font-semibold text-green-900 mb-1">Course Rating</label>
          <input type="number" step="0.1" name="rating" required class="block w-full rounded-md border-gray-300 shadow-sm focus:border-green-600 focus:ring-green-600" />
        </div>
        <div class="rounded-xl border border-green-200 bg-green-50 p-4 shadow-sm mb-2">
          <label class="block text-sm font-semibold text-green-900 mb-1">Slope</label>
          <input type="number" name="slope" required class="block w-full rounded-md border-gray-300 shadow-sm focus:border-green-600 focus:ring-green-600" />
        </div>
        <div class="rounded-xl border border-green-200 bg-green-50 p-4 shadow-sm mb-2">
        <label class="block text-sm font-semibold text-green-900 mb-1">Par</label>
        <input type="number" name="par" required class="block w-full rounded-md border-gray-300 shadow-sm focus:border-green-600 focus:ring-green-600" />
      </div>
      </div>
      <button type="submit" class="w-full bg-green-600 text-white py-3 px-4 rounded-md font-semibold hover:bg-green-700 transition-colors">
        Save Course
      </button>
    </form>
  </main>
</Layout>
