---
// src/pages/reset-password.astro
//
// TWO-STEP FLOW:
// 1. Request step  → server-side POST to send reset email
// 2. Update step   → client-side ONLY (Supabase puts recovery tokens in the
//                    URL hash, which the server never sees, so updateUser()
//                    must be called from the browser via the Supabase JS client)

import { createClient } from '@supabase/supabase-js';

const supabaseUrl    = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

let serverMessage = '';
let serverError   = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email    = formData.get('email') as string;

  const supabase = createClient(supabaseUrl, supabaseAnonKey, {
    auth: {
      flowType: 'implicit',
      persistSession: false,
      autoRefreshToken: false,
    },
  });

  const { error } = await supabase.auth.resetPasswordForEmail(email, {
    redirectTo: `${Astro.url.origin}/reset-password`,
  });

  if (error) serverError   = error.message;
  else        serverMessage = 'Check your email for a password reset link.';
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Password</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0c0c0f; --surface: #14141a; --border: #1e1e2a; --border-hover: #2e2e40;
      --text: #e8e8f0; --text-muted: #6b6b80;
      --accent: #c8a96e; --accent-dim: rgba(200,169,110,.12); --accent-glow: rgba(200,169,110,.2);
      --error: #e05c5c; --error-dim: rgba(224,92,92,.1);
      --success: #5cc8a0; --success-dim: rgba(92,200,160,.1);
    }
    html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; font-weight: 300; }
    body {
      display: grid; place-items: center; min-height: 100vh; padding: 2rem;
      position: relative; overflow: hidden;
    }
    body::before, body::after {
      content: ''; position: fixed; border-radius: 50%; filter: blur(80px); opacity: .3; pointer-events: none;
    }
    body::before { width: 500px; height: 500px; background: radial-gradient(circle, rgba(200,169,110,.4), transparent 70%); top: -150px; right: -150px; }
    body::after  { width: 400px; height: 400px; background: radial-gradient(circle, rgba(80,80,180,.3),  transparent 70%); bottom: -100px; left: -100px; }

    .card {
      width: 100%; max-width: 420px; background: var(--surface);
      border: 1px solid var(--border); border-radius: 20px; padding: 3rem 2.5rem;
      position: relative; animation: fadeUp .6s cubic-bezier(.16,1,.3,1) both;
    }
    .card::before {
      content: ''; position: absolute; inset: 0; border-radius: 20px;
      background: linear-gradient(135deg, rgba(200,169,110,.05) 0%, transparent 60%); pointer-events: none;
    }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }

    .icon-wrap {
      width: 52px; height: 52px; border-radius: 14px;
      border: 1px solid var(--border-hover); background: var(--accent-dim);
      display: grid; place-items: center; margin-bottom: 1.75rem;
    }
    .icon-wrap svg { width: 22px; height: 22px; stroke: var(--accent); }

    h1 { font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 400; letter-spacing: -.02em; margin-bottom: .5rem; }
    .subtitle { font-size: .875rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 2rem; }

    .alert {
      border-radius: 10px; padding: .875rem 1rem; font-size: .85rem;
      margin-bottom: 1.5rem; line-height: 1.5; display: flex; align-items: flex-start; gap: .625rem;
    }
    .alert.error   { background: var(--error-dim);   border: 1px solid rgba(224,92,92,.25);  color: var(--error);   }
    .alert.success { background: var(--success-dim); border: 1px solid rgba(92,200,160,.25); color: var(--success); }
    .alert.hidden  { display: none; }
    .alert svg { flex-shrink: 0; margin-top: 1px; }

    .field { margin-bottom: 1.25rem; }
    label { display: block; font-size: .8rem; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: .5rem; }
    input {
      width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 10px;
      padding: .75rem 1rem; color: var(--text); font-family: 'DM Sans', sans-serif;
      font-size: .95rem; font-weight: 300; outline: none; transition: border-color .2s, box-shadow .2s;
    }
    input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
    input::placeholder { color: var(--text-muted); opacity: .5; }

    .btn {
      width: 100%; margin-top: .5rem; padding: .875rem; background: var(--accent);
      color: #0c0c0f; border: none; border-radius: 10px; font-family: 'DM Sans', sans-serif;
      font-size: .925rem; font-weight: 500; cursor: pointer; letter-spacing: .01em;
      transition: opacity .2s, transform .15s;
    }
    .btn:hover    { opacity: .9; transform: translateY(-1px); }
    .btn:active   { transform: none; }
    .btn:disabled { opacity: .5; cursor: not-allowed; transform: none; }

    .back-link {
      display: flex; align-items: center; gap: .375rem; margin-top: 1.75rem;
      font-size: .85rem; color: var(--text-muted); text-decoration: none; transition: color .2s;
    }
    .back-link:hover { color: var(--accent); }
    .back-link svg { width: 14px; height: 14px; }

    .strength-bar { height: 3px; border-radius: 2px; background: var(--border); margin-top: .5rem; overflow: hidden; }
    .strength-fill { height: 100%; border-radius: 2px; transition: width .3s, background .3s; width: 0%; }

    /* Panels */
    #request-panel, #update-panel { display: none; }
    #request-panel.active, #update-panel.active { display: block; }
  </style>
</head>
<body>
  <div class="card">

    <div class="icon-wrap" id="icon-wrap">
      <!-- email icon (default) -->
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
      </svg>
    </div>

    <h1 id="heading">Forgot password?</h1>
    <p class="subtitle" id="subtitle">Enter your email and we'll send you a secure reset link.</p>

    <!-- Dynamic alert (used by client-side JS) -->
    <div class="alert hidden" id="alert-box">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" id="alert-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
      </svg>
      <span id="alert-text"></span>
    </div>

    <!-- Server-rendered alerts for the email-request step -->
    {serverError && (
      <div class="alert error">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        {serverError}
      </div>
    )}
    {serverMessage && (
      <div class="alert success">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        {serverMessage}
      </div>
    )}

    <!-- Panel 1: Request reset email -->
    <div id="request-panel">
      <form method="POST">
        <div class="field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email" />
        </div>
        <button type="submit" class="btn">Send reset link</button>
      </form>
    </div>

    <!-- Panel 2: Set new password (client-side) -->
    <div id="update-panel">
      <div class="field">
        <label for="password">New password</label>
        <input type="password" id="password" placeholder="Min. 8 characters" minlength="8" autocomplete="new-password" />
        <div class="strength-bar"><div class="strength-fill" id="strength-fill"></div></div>
      </div>
      <div class="field">
        <label for="confirm">Confirm password</label>
        <input type="password" id="confirm" placeholder="Repeat your password" minlength="8" autocomplete="new-password" />
      </div>
      <button class="btn" id="update-btn">Update password</button>
    </div>

    <a href="/login" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
      Back to login
    </a>
  </div>

  <!--
    Pass PUBLIC_ env vars to the browser.
    Astro's define:vars inlines them as a regular script at build time.
  -->
  <script define:vars={{ supabaseUrl, supabaseAnonKey }}>
    window.__SB_URL  = supabaseUrl;
    window.__SB_ANON = supabaseAnonKey;
  </script>

  <script type="module">
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';

    const supabase = createClient(window.__SB_URL, window.__SB_ANON, {
      auth: {
        // Required so the client automatically exchanges the hash tokens
        detectSessionInUrl: true,
        persistSession: true,
        flowType: 'implicit',
      }
    });

    // ── UI refs ──────────────────────────────────────────────────────────────
    const requestPanel = document.getElementById('request-panel');
    const updatePanel  = document.getElementById('update-panel');
    const heading      = document.getElementById('heading');
    const subtitle     = document.getElementById('subtitle');
    const iconWrap     = document.getElementById('icon-wrap');
    const alertBox     = document.getElementById('alert-box');
    const alertText    = document.getElementById('alert-text');
    const alertIcon    = document.getElementById('alert-icon');

    const KEY_ICON    = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:22px;height:22px;stroke:#c8a96e"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z" /></svg>`;
    const ERROR_PATH  = '<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />';
    const CHECK_PATH  = '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />';

    function showAlert(msg, type = 'error') {
      alertBox.className  = `alert ${type}`;
      alertText.textContent = msg;
      alertIcon.innerHTML = type === 'success' ? CHECK_PATH : ERROR_PATH;
    }

    function showUpdatePanel() {
      requestPanel.classList.remove('active');
      updatePanel.classList.add('active');
      heading.textContent  = 'New password';
      subtitle.textContent = 'Choose a strong password to secure your account.';
      iconWrap.innerHTML   = KEY_ICON;
    }

    function showRequestPanel() {
      updatePanel.classList.remove('active');
      requestPanel.classList.add('active');
    }

    // ── Detect recovery session ───────────────────────────────────────────────
    // onAuthStateChange fires with PASSWORD_RECOVERY when Supabase parses the
    // URL recovery payload and creates a session.
    supabase.auth.onAuthStateChange((event) => {
      if (event === 'PASSWORD_RECOVERY') showUpdatePanel();
    });

    async function establishRecoverySessionFromUrl() {
      const queryParams = new URLSearchParams(window.location.search);
      const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ''));

      const tokenHash = queryParams.get('token_hash') || hashParams.get('token_hash');
      const type = queryParams.get('type') || hashParams.get('type');
      const errorDescription = queryParams.get('error_description') || hashParams.get('error_description');

      if (errorDescription) {
        showAlert(decodeURIComponent(errorDescription));
        return;
      }

      let exchangeError = null;

      if (tokenHash && type === 'recovery') {
        const { error } = await supabase.auth.verifyOtp({
          type: 'recovery',
          token_hash: tokenHash,
        });
        exchangeError = error;
      }

      if (exchangeError) {
        showAlert(exchangeError.message || 'This reset link is invalid or expired. Request a new one.');
        return;
      }

      if (tokenHash) {
        queryParams.delete('token_hash');
        queryParams.delete('type');
        queryParams.delete('error');
        queryParams.delete('error_description');

        hashParams.delete('token_hash');
        hashParams.delete('type');
        hashParams.delete('error');
        hashParams.delete('error_description');

        const newSearch = queryParams.toString();
        const newHash = hashParams.toString();
        const cleanUrl = `${window.location.pathname}${newSearch ? `?${newSearch}` : ''}${newHash ? `#${newHash}` : ''}`;
        window.history.replaceState({}, document.title, cleanUrl);
      }
    }

    await establishRecoverySessionFromUrl();

    // Also check if there's already an active session (page reload scenario)
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      showUpdatePanel();
    } else {
      showRequestPanel();
    }

    // ── Password strength meter ───────────────────────────────────────────────
    document.getElementById('password')?.addEventListener('input', (e) => {
      const v = e.target.value;
      let score = 0;
      if (v.length >= 8)           score++;
      if (v.length >= 12)          score++;
      if (/[A-Z]/.test(v))         score++;
      if (/[0-9]/.test(v))         score++;
      if (/[^A-Za-z0-9]/.test(v))  score++;
      const colors = ['#e05c5c','#e08a5c','#e0c45c','#9ec85c','#5cc8a0'];
      const fill = document.getElementById('strength-fill');
      fill.style.width      = (score / 5 * 100) + '%';
      fill.style.background = colors[score - 1] ?? 'transparent';
    });

    // ── Update password ───────────────────────────────────────────────────────
    document.getElementById('update-btn')?.addEventListener('click', async () => {
      const password = document.getElementById('password').value;
      const confirm  = document.getElementById('confirm').value;

      if (password.length < 8) {
        showAlert('Password must be at least 8 characters.');
        return;
      }
      if (password !== confirm) {
        showAlert('Passwords do not match.');
        return;
      }

      const btn = document.getElementById('update-btn');
      btn.disabled = true;
      btn.textContent = 'Updating…';

      const { error } = await supabase.auth.updateUser({ password });

      if (error) {
        showAlert(error.message);
        btn.disabled = false;
        btn.textContent = 'Update password';
      } else {
        showAlert('Password updated! Redirecting…', 'success');
        await supabase.auth.signOut();
        setTimeout(() => { window.location.href = '/login?reset=success'; }, 1500);
      }
    });
  </script>
</body>
</html>