---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Update Password | Golf Handicap">
  <main class="flex min-h-screen items-center justify-center bg-green-50 px-4">
    <div class="w-full max-w-md space-y-8 rounded-xl bg-white p-10 shadow-lg">
      <div class="text-center">
        <h2 class="text-2xl font-extrabold text-green-900">Set a New Password</h2>
        <p class="mt-2 text-gray-600">Enter your new password below.</p>
      </div>
      <form id="updateForm" class="space-y-4">
        <input type="password" name="password" placeholder="New Password" class="w-full rounded-md border-gray-300 p-2 shadow-sm focus:border-green-500 focus:ring-green-500" required />
        <button type="submit" class="w-full rounded-md bg-green-600 py-2 text-white hover:bg-green-700">Update Password</button>
        <div id="updateError" class="mt-2 text-red-600 font-semibold"></div>
        <div id="updateSuccess" class="mt-2 text-green-600 font-semibold"></div>
      </form>
      <p class="text-center mt-4 text-sm text-gray-600">
        <a href="/login" class="text-green-700 hover:underline font-semibold">Back to Sign In</a>
      </p>
      <script type="module">
        import { browserSupabase } from '../lib/browserSupabase.js';

        // Helper to get URL params
        function getParam(name) {
          return new URLSearchParams(window.location.search).get(name);
        }

        // If access_token is present, set the session
        const access_token = getParam('access_token');
        const refresh_token = getParam('refresh_token');
        if (access_token && refresh_token) {
          browserSupabase.auth.setSession({ access_token, refresh_token });
        }

        document.getElementById('updateForm').addEventListener('submit', async function(e) {
          e.preventDefault();
          const form = e.target;
          const formData = new FormData(form);
          const errorDiv = document.getElementById('updateError');
          const successDiv = document.getElementById('updateSuccess');
          errorDiv.textContent = '';
          successDiv.textContent = '';
          // Optionally, update password directly with Supabase client
          if (access_token && refresh_token) {
            const { error } = await browserSupabase.auth.updateUser({ password: formData.get('password') });
            if (error) {
              errorDiv.textContent = error.message || 'An error occurred.';
              return;
            }
            successDiv.textContent = 'Your password has been updated.';
            return;
          }
          // Fallback: call server API
          const res = await fetch('/api/auth/update-password', {
            method: 'POST',
            body: formData
          });
          const data = await res.json();
          if (res.ok) {
            successDiv.textContent = 'Your password has been updated.';
          } else {
            errorDiv.textContent = data.error || 'An error occurred.';
          }
        });
      </script>
    </div>
  </main>
</Layout>
