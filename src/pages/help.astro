---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="max-w-2xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-bold mb-4 text-green-700">Help & FAQ</h1>
    <p class="mb-6">Welcome to the help page! Here you can find answers to common questions and tips for using the GolfHandicap app.</p>
    <ul class="list-disc pl-6 space-y-2">
      <li><strong>How do I add a round?</strong> Use the "Add Round" button on your dashboard to enter your latest golf score.</li>
      <li><strong>How is my handicap calculated?</strong> The app uses the World Handicap System formula for accurate results.</li>
      <li><strong>How do I reset my password?</strong> Go to the login page and click "Forgot password?" to receive a reset link.</li>
      <li><strong>Need more help?</strong> Contact support via the feedback form or email listed in the app footer.</li>
    </ul>
  </section>
</Layout>
