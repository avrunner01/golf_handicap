---
import Layout from '../layouts/Layout.astro';
import { supabaseClient } from '../lib/supabase';

const supabase = supabaseClient(Astro);
const { data: { user } } = await supabase.auth.getUser();

let rounds: { id: string; course_name: string | null; played_at: string | null; gross_score: number | null }[] = [];
if (user) {
  const { data } = await supabase
    .from('rounds')
    .select('id, course_name, played_at, gross_score')
    .eq('profile_id', user.id)
    .order('played_at', { ascending: false });
  rounds = data || [];
}

const formatLocalDate = (value: string | null | undefined) => {
  if (!value) return '';
  const [y, m, d] = String(value).split('T')[0].split('-');
  if (y && m && d) {
    const parsed = new Date(Number(y), Number(m) - 1, Number(d));
    if (!Number.isNaN(parsed.getTime())) return parsed.toLocaleDateString();
  }
  return String(value);
};
---

<Layout title="Delete Round">

  <main class="max-w-2xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Delete a Round</h1>
    {user ? (
      <>
        {rounds.length === 0 ? (
          <p class="text-gray-600">No rounds to delete.</p>
        ) : (
          <ul class="space-y-4">
            {rounds.map(round => (
              <li class="flex items-center justify-between bg-white p-4 rounded shadow border">
                <div>
                  <div class="font-semibold">{round.course_name}</div>
                  <div class="text-sm text-gray-500">{formatLocalDate(round.played_at)}</div>
                  <div class="text-sm text-gray-700">Score: {round.gross_score}</div>
                </div>
                <form class="delete-round-form" data-round-id={round.id}>
                  <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700">Delete</button>
                </form>
              </li>
            ))}
          </ul>
        )}
      </>
    ) : (
      <p class="text-red-600">You must be signed in to delete rounds.</p>
    )}
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.delete-round-form').forEach(function (form) {
      form.addEventListener('submit', async function (event) {
        event.preventDefault();
        const roundId = form.getAttribute('data-round-id');
        const res = await fetch('/api/rounds/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: roundId })
        });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to delete round.');
        }
      });
    });
  });
</script>
