---
import Layout from "../layouts/Layout.astro";
import { supabaseClient } from "../lib/supabase";

const supabase = supabaseClient(Astro);
const { data: { user } } = await supabase.auth.getUser();

const videos = [
  {
    title: "Golf Club Takeaway",
    src: "https://www.youtube.com/embed/tYsjzK0Hr_I?start=2",
    description: "Build a more consistent takeaway for cleaner ball striking.",
  },
  {
    title: "Grip And Setup Basics",
    src: "https://www.youtube.com/embed/LTHQtOX1fac?start=2",
    description: "Dial in fundamentals before you work on speed and power.",
  },
  {
    title: "Tempo And Rhythm",
    src: "https://www.youtube.com/embed/dUNC877IePA?start=2",
    description: "Use tempo checkpoints to improve contact and control.",
  },
  {
    title: "Hands Low Drills",
    src: "https://www.youtube.com/embed/ZnMSmumxrDE?start=2",
    description: "Keep Hands Low drills to improve contact and consistency.",
  },
  {
    title: "Down Swing Sequence",
    src: "https://www.youtube.com/embed/Gtukt9c5Tvk?start=2",
    description: "Turn Down to start down-swing.",
  },
  {
    title: "Putting Tips",
    src: "https://www.youtube.com/embed/0DsErZEF0A8?start=2",
    description: "Speed control on the greens.",
  },
  {
    title: "Putting Tips",
    src: "https://www.youtube.com/embed/qp6k5d8FJOA?start=2",
    description: "Improve your putting skills with these tips.",
  },
];
---
<Layout title="Golf Videos" user={user}>
  <main class="max-w-3xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-extrabold text-green-800 mb-8 text-center">Golf Videos</h1>
    <div class="grid gap-8 md:grid-cols-2">
      {videos.map((video) => (
        <article class="bg-white rounded-xl shadow p-4 border border-green-100">
          <h2 class="text-lg font-bold text-blue-700 mb-2">{video.title}</h2>
          <div class="aspect-w-16 aspect-h-9 mb-2">
            <iframe
              class="rounded-lg w-full h-56"
              src={video.src}
              title={video.title}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
          <p class="text-gray-600 text-sm">{video.description}</p>
        </article>
      ))}
    </div>
  </main>
</Layout>
