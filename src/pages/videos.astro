---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Golf Videos">
  <main class="max-w-3xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-extrabold text-green-800 mb-8 text-center">Golf Videos</h1>
    <div class="grid gap-8 md:grid-cols-2">
      <div class="bg-white rounded-xl shadow p-4 border border-green-100">
        <h2 class="text-lg font-bold text-blue-700 mb-2">How to Break 80 in Golf</h2>
        <div class="aspect-w-16 aspect-h-9 mb-2">
          <iframe class="rounded-lg w-full h-56" src="https://www.youtube.com/embed/1bGZ3QJ5Q2A" title="How to Break 80 in Golf" frameborder="0" allowfullscreen></iframe>
        </div>
        <p class="text-gray-600 text-sm">Tips and strategies to help you consistently shoot in the 70s.</p>
      </div>
      <div class="bg-white rounded-xl shadow p-4 border border-green-100">
        <h2 class="text-lg font-bold text-blue-700 mb-2">Golf Swing Basics for Beginners</h2>
        <div class="aspect-w-16 aspect-h-9 mb-2">
          <iframe class="rounded-lg w-full h-56" src="https://www.youtube.com/embed/2v2JZCkU4gk" title="Golf Swing Basics for Beginners" frameborder="0" allowfullscreen></iframe>
        </div>
        <p class="text-gray-600 text-sm">Learn the fundamentals of a great golf swing, perfect for new players.</p>
      </div>
      <div class="bg-white rounded-xl shadow p-4 border border-green-100">
        <h2 class="text-lg font-bold text-blue-700 mb-2">Short Game Mastery</h2>
        <div class="aspect-w-16 aspect-h-9 mb-2">
          <iframe class="rounded-lg w-full h-56" src="https://www.youtube.com/embed/3Q8pQ5b6QwA" title="Short Game Mastery" frameborder="0" allowfullscreen></iframe>
        </div>
        <p class="text-gray-600 text-sm">Improve your chipping, pitching, and putting to lower your scores.</p>
      </div>
      <div class="bg-white rounded-xl shadow p-4 border border-green-100">
        <h2 class="text-lg font-bold text-blue-700 mb-2">How to Hit a Draw and Fade</h2>
        <div class="aspect-w-16 aspect-h-9 mb-2">
          <iframe class="rounded-lg w-full h-56" src="https://www.youtube.com/embed/4Q1FQKp5QwA" title="How to Hit a Draw and Fade" frameborder="0" allowfullscreen></iframe>
        </div>
        <p class="text-gray-600 text-sm">Learn to shape your shots for more control on the course.</p>
      </div>
      <!-- Golf Lesson Video -->
      <div class="bg-white rounded-xl shadow p-4 border border-green-100">
        <h2 class="text-lg font-bold text-blue-700 mb-2">Golf Lesson: Improve Your Swing</h2>
        <div class="aspect-w-16 aspect-h-9 mb-2">
          <iframe class="rounded-lg w-full h-56" src="https://www.youtube.com/embed/6k2zQGgGgJw" title="Golf Lesson: Improve Your Swing" frameborder="0" allowfullscreen></iframe>
        </div>
        <p class="text-gray-600 text-sm">A professional golf lesson focusing on swing fundamentals and drills to help you play better golf.</p>
      </div>
    </div>
  </main>
</Layout>
