---
interface Props {
  scores: { date: string; differential: number }[];
}
const { scores } = Astro.props;

const parseLocalDate = (value: string) => {
  const [y, m, d] = String(value).split('T')[0].split('-');
  if (y && m && d) {
    return new Date(Number(y), Number(m) - 1, Number(d));
  }
  return new Date(value);
};

const formatLocalDate = (value: string) => {
  const parsed = parseLocalDate(value);
  return Number.isNaN(parsed.getTime()) ? String(value) : parsed.toLocaleDateString();
};

// Sort by date and take the last 10 rounds
const chartData = scores
  .sort((a, b) => parseLocalDate(a.date).getTime() - parseLocalDate(b.date).getTime())
  .slice(-10);
---

<div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm mb-8">
  <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-4">Handicap Trend (Last 10 Rounds)</h3>
  <canvas id="handicapChart"></canvas>
</div>

<script define:vars={{ chartData }}>
  import Chart from 'chart.js/auto';

  const ctx = document.getElementById('handicapChart');
  
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: chartData.map(d => formatLocalDate(d.date)),
      datasets: [{
        label: 'Differential',
        data: chartData.map(d => d.differential),
        borderColor: '#16a34a', // Tailwind green-600
        backgroundColor: 'rgba(22, 163, 74, 0.1)',
        fill: true,
        tension: 0.4,
        pointRadius: 5,
        pointBackgroundColor: '#16a34a'
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: false, grid: { display: false } },
        x: { grid: { display: false } }
      }
    }
  });
</script>