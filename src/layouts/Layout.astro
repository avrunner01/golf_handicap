---
import "../styles/global.css";
import Footer from '../components/Footer.astro';
import { supabaseClient } from "../lib/supabase";

const supabase = supabaseClient(Astro);
let sessionUser = null;
try {
  const { data, error } = await supabase.auth.getUser();
  if (!error) sessionUser = data.user;
} catch (_) {}
const user = Astro.props.user ?? sessionUser;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/golf-ball.svg" />
		<link rel="icon" type="image/png" href="/golf-ball.jpg" sizes="32x32" />
		<link rel="apple-touch-icon" href="/golf-ball.svg" sizes="180x180" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#005c80" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="application-name" content="GolfHandicap" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="GolfHandicap" />
		<meta name="description" content="Track your golf scores and handicap easily on any device." />
		<title>GolfHandicapBasics ⛳</title>
	</head>
	<body>
						<nav class="sticky top-0 z-50 bg-linear-to-r from-blue-900 via-blue-700 to-sky-600 shadow-lg flex items-center justify-between px-8 py-4 mb-8 border-b border-blue-950">
							<div class="flex gap-8 items-center">
								<a href="/" class="font-extrabold text-2xl text-white tracking-tight hover:text-sky-100 hover:underline transition-colors flex items-center gap-2">
									<img src="/golf-ball.svg" alt="Golf Ball Logo" width="32" height="32" class="inline-block align-middle" />
									GolfHandicap Home
								</a>
								<a href="/videos" class="font-bold text-white hover:text-sky-100 hover:underline transition-colors">Videos</a>
								<a href="/playing" class="font-bold text-white hover:text-sky-100 hover:underline transition-colors">Playing</a>
								<a href="/help" class="font-bold text-white hover:text-sky-100 hover:underline transition-colors">Help</a>
								<a href="/contact" class="font-bold text-white hover:text-sky-100 hover:underline transition-colors">Contact</a>
							</div>
							{user ? (
								<form action="/api/auth/signout" method="POST">
									<button type="submit" class="rounded-lg bg-white text-blue-800 px-5 py-2 font-extrabold shadow hover:bg-sky-50 transition-all">Sign Out</button>
								</form>
							) : (
								<a href="/login" class="rounded-lg bg-white text-blue-800 px-5 py-2 font-extrabold shadow hover:bg-sky-50 transition-all">Signin</a>
							)}
						</nav>
		<slot />
		<Footer />
	</body>

</html>
<style>
html,
body {
	margin: 0;
	background: linear-gradient(135deg, #dbeafe 0%, #e0f2fe 52%, #f0f9ff 100%);
}
</style>

