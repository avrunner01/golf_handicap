---
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/src/assets/golf-ball.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>GolfHandicapBasics ⛳</title>
	</head>
	<body>
						<nav class="sticky top-0 z-50 bg-gradient-to-r from-green-100 via-blue-100 to-green-200 shadow-lg flex items-center justify-between px-8 py-4 mb-10 border-b border-blue-200" style="border-radius: 0 0 1.5rem 1.5rem;">
							<div class="flex gap-8 items-center">
								<a href="/" class="font-extrabold text-2xl text-green-700 tracking-tight hover:text-blue-700 transition-colors flex items-center gap-2">
									<img src="/golf-ball.svg" alt="Golf Ball Logo" width="32" height="32" class="inline-block align-middle" />
									GolfHandicap Home
								</a>
								<a href="/videos" class="font-semibold text-blue-700 hover:text-green-700 transition-colors">Videos</a>
								<a href="/playing" class="font-semibold text-blue-700 hover:text-green-700 transition-colors">Playing</a>
							</div>
							{Astro.props.user ? (
								<form action="/api/auth/signout" method="POST">
									<button type="submit" class="rounded-lg bg-gradient-to-r from-red-500 to-pink-500 text-white px-5 py-2 font-bold shadow hover:from-pink-600 hover:to-red-600 transition-all">Sign Out</button>
								</form>
							) : (
								<a href="/login" class="rounded-lg bg-gradient-to-r from-green-500 to-blue-500 text-white px-5 py-2 font-bold shadow hover:from-blue-600 hover:to-green-600 transition-all">Signin</a>
							)}
						</nav>

		</nav>
		<slot />
	</body>
</html>

<style>
html,
body {
	background: linear-gradient(135deg, #e0f7fa 0%, #f1f8e9 100%);
}
</style>

